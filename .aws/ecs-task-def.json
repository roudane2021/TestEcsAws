{
  "family": "gestion-commande-def-family",
  "networkMode": "awsvpc",
  "containerDefinitions": [
    {
      "name": "gestion-commande",
      "image": "585008070520.dkr.ecr.eu-west-1.amazonaws.com/dev/gestion-commande:latest",
      "portMappings": [
        {
          "containerPort": 8180,
          "hostPort": 8180
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/gestion-commande",
          "awslogs-region": "eu-west-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::585008070520:role/ecsTaskExecutionRoleNoorGitHub",
  "taskRoleArn": "arn:aws:iam::585008070520:role/ecsTaskRoleNoorGitHub"
}
